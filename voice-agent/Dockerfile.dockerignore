# Scoped ignore for voice-agent/Dockerfile (used by BuildKit instead of the
# repo-root .dockerignore). Keeps the demo-site HTML and other unrelated files
# out of the build context — only voice-agent/ and the fallback JSON are copied.
.git
generated-sites
gainesville-no-website/*.xlsx
gainesville-no-website/*.txt
*.html
voice-agent/.env
voice-agent/.venv
voice-agent/audio_cache
voice-agent/call-log.csv
voice-agent/__pycache__
**/__pycache__
