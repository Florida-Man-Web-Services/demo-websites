# --- Claude (conversation brain, default) -----------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# VOICE_AGENT_MODEL=claude-opus-4-8

# --- Grok (alternative conversation brain) ----------------------------------
# Set LLM_PROVIDER=grok to run calls on xAI's Grok instead of Claude
# (key from console.x.ai; ANTHROPIC_API_KEY is then not needed).
# LLM_PROVIDER=anthropic
# XAI_API_KEY=xai-...
# GROK_MODEL=grok-4.3

# --- Grok realtime voice (speech-to-speech, replaces the whole pipeline) -----
# VOICE_BACKEND=grok-realtime streams call audio straight to xAI's realtime
# API: no Whisper, no Sesame, sub-second turns. Needs XAI_API_KEY only.
# VOICE_BACKEND=pipeline
# XAI_VOICE_AGENT_ID=agent_...   # optional console.x.ai voice agent
# GROK_VOICE=eve                 # eve | ara | rex | sal | leo | custom ID
# GROK_VAD_SILENCE_MS=600        # silence that ends the caller's turn

# --- Sesame CSM-1B voice (via DeepInfra, $7 / 1M characters) ----------------
DEEPINFRA_API_KEY=...
# Point at a self-hosted csm-1b or other compatible endpoint instead:
# SESAME_TTS_URL=https://api.deepinfra.com/v1/inference/sesame/csm-1b

# --- Twilio (phone + SMS) ----------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1352...

# Public HTTPS URL that reaches this server (ngrok / cloudflared / VPS).
# e.g. run `ngrok http 8035` and paste the https URL here.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# --- Identity ----------------------------------------------------------------
OWNER_NAME=Noah
# Number given out for "talk to a human" requests (defaults to the Twilio number)
# OWNER_CALLBACK_NUMBER=+1352...
