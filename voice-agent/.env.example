# --- Claude (conversation brain, default) -----------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# VOICE_AGENT_MODEL=claude-opus-4-8

# --- Grok (alternative conversation brain) ----------------------------------
# Set LLM_PROVIDER=grok to run calls on xAI's Grok instead of Claude
# (key from console.x.ai; ANTHROPIC_API_KEY is then not needed).
# LLM_PROVIDER=anthropic
# XAI_API_KEY=xai-...
# GROK_MODEL=grok-4.3

# --- Grok realtime voice (speech-to-speech, replaces the whole pipeline) -----
# VOICE_BACKEND=grok-realtime streams call audio straight to xAI's realtime
# API: no Whisper, no Sesame, sub-second turns. Needs XAI_API_KEY only.
# VOICE_BACKEND=pipeline
# XAI_VOICE_AGENT_ID=agent_...   # AVOID: console agents auto-greet in PCM16 before
#                                 # our mu-law session.update applies -> loud static
# GROK_VOICE=eve                 # eve | ara | rex | sal | leo | custom ID
# GROK_VAD_SILENCE_MS=600        # silence that ends the caller's turn

# --- Sesame CSM-1B voice (via DeepInfra, $7 / 1M characters) ----------------
DEEPINFRA_API_KEY=...
# Point at a self-hosted csm-1b or other compatible endpoint instead:
# SESAME_TTS_URL=https://api.deepinfra.com/v1/inference/sesame/csm-1b

# --- Twilio (phone + SMS) ----------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1352...

# Public HTTPS URL that reaches this server (ngrok / cloudflared / VPS).
# e.g. run `ngrok http 8035` and paste the https URL here.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# --- Demo site links ---------------------------------------------------------
# Where demo links texted/spoken to businesses point. Defaults to GitHub Pages
# with guessable /<slug>.html paths. Once floridamanweb.online is live, switch
# to unguessable content-hash URLs (served by hosting/Dockerfile):
# DEMO_URL_STYLE=hash
# DEMO_BASE_URL=https://floridamanweb.online
# GENERATED_SITES_DIR=/path/to/generated-sites   # defaults to the repo copy

# --- Identity ----------------------------------------------------------------
OWNER_NAME=Noah
# Number given out for "talk to a human" requests (defaults to the Twilio number)
# OWNER_CALLBACK_NUMBER=+1352...

# --- Agent mode --------------------------------------------------------------
# sales (default): Florida Man Web Services demo-website pitch agent.
# ai411: Gainesville AI 411 directory / events / broadcast operator (#51).
# owner_updates: owner site ChangeRequest intake desk (#52).
# VOICE_AGENT_MODE is accepted as an alias for AGENT_MODE.
# AGENT_MODE=sales
# AGENT_MODE=ai411
# AGENT_MODE=owner_updates
#
# AI 411 MCP bridge — how tools reach knowledge/events/callers/broadcasts:
#   MCP_MODE=inproc (default) — import mcp-server modules from monorepo checkout
#   MCP_MODE=http             — Streamable HTTP tools/call to MCP_URL
#   MCP_MODE=auto             — try inproc; fall back to http if import fails + MCP_URL set
# Production voice containers without the mcp-server filesystem should use http/auto:
# MCP_MODE=http
# MCP_URL=https://mcp.flmanbiosci.net/mcp
# MCP_AUTH_TOKEN=...   # same Bearer as demo-mcp (Vaultwarden demo-mcp-auth)
#
# AI 411 store paths (mcp-server modules, in-process). Defaults match mcp-server:
#   KNOWLEDGE_DIR  → repo generated-sites/
#   EVENTS_PATH    → /data/events.json or repo data/events.json
#   CALLERS_PATH   → /data/callers.json
#   BROADCASTS_PATH→ /data/broadcasts.jsonl
# Override for tests or PVC mounts:
# KNOWLEDGE_DIR=/path/to/generated-sites
# EVENTS_PATH=/data/events.json
# CALLERS_PATH=/data/callers.json
# BROADCASTS_PATH=/data/broadcasts.jsonl
#
# Owner updates (#52) store paths:
# CHANGE_REQUESTS_PATH=/data/change-requests.jsonl
# GENERATED_SITES_DIR=/path/to/generated-sites
